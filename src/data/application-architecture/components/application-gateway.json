{
  "azureService": "Application Gateway",
  "sku": "WAF v2",
  "region": "East US 2",
  "settings": {
    "tier": "WAF_v2",
    "capacity": "2",
    "wafMode": "Prevention",
    "wafRuleSet": "OWASP 3.2",
    "sslCertificate": "Azure Key Vault",
    "publicIp": "Static",
    "backendPools": ["Web Frontend", "API Backend"],
    "healthProbes": "Enabled",
    "cookieBasedAffinity": "Disabled"
  }
}
