{
  "name": "@zureltd/az-infra-harness",
  "version": "0.23.0",
  "description": "Interactive planning tool for Azure infrastructure — generates production-ready Bicep or Terraform code from guided decisions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zure/az-infra-harness"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "az-infra-harness": "./bin/cli.js"
  },
  "files": [
    ".next/standalone",
    ".next/static",
    "public",
    "bin",
    ".claude",
    ".opencode",
    ".github/prompts",
    ".github/skills",
    "skills"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run postbuild",
    "postbuild": "cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static && cp -r demo .next/standalone/demo",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prepack": "npm run build && cp -r ../.claude . && cp -r ../.opencode . && mkdir -p .github && cp -r ../.github/prompts .github/ && cp -r ../.github/skills .github/ && cp -r ../skills .",
    "postpack": "rm -rf .claude .opencode skills && rm -rf .github/prompts .github/skills",
    "prepublishOnly": "echo 'Run npm pack first to verify the tarball before publishing'"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/archiver": "^7.0.0",
    "archiver": "^8.0.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.12.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^6",
    "vitest": "^4.0.18"
  }
}
